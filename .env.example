# Provider: gemini | openai_compatible | xai
LLM_PROVIDER=gemini
GEMINI_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-3.1-flash-lite
LLM_TIMEOUT_SECONDS=45
LLM_FORCE_JSON_MODE=false
LLM_USE_REDUCE=true

# Gemini Vision OCR (PDF scan)
OCR_MODE=auto
OCR_MODEL=gemini-3.1-flash-lite
OCR_CONCURRENCY=8
OCR_DPI=180
CHART_VISION=auto

# Server
HOST=0.0.0.0
PORT=8090
CORS_ORIGINS=*
MAX_PAGES_BUDGET=0
TARGET_SECONDS=55
MAP_CONCURRENCY=8
MAX_MAP_CHUNKS=40
MAX_CHARS_PER_CHUNK=8000
CHUNK_PAGES=15
