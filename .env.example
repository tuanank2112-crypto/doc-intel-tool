# Provider: openai_compatible | gemini | xai
LLM_PROVIDER=openai_compatible

# 9flare (OpenAI-compatible)
LLM_API_KEY=flr-your_key_here
LLM_BASE_URL=https://9flare.com/api/v1
LLM_MODEL=pro/claude-haiku-4-5

# Or Gemini:
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-flash-lite-latest

# Or SpaceXAI / xAI:
# LLM_PROVIDER=xai
# XAI_API_KEY=
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_MODEL=grok-4.5

# Server
HOST=0.0.0.0
PORT=8090
MAX_PAGES_BUDGET=0
TARGET_SECONDS=55
MAP_CONCURRENCY=4
CHUNK_PAGES=10

# Gemini Vision OCR — PDF page images → text (no separate OCR engine)
OCR_MODE=auto
OCR_MODEL=gemini-2.5-flash
OCR_CONCURRENCY=10
OCR_DPI=150
GEMINI_API_KEY=
